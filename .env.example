# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# App — use a URL pública (produção ou preview). Obrigatório no Vercel para links de convite e redefinição de senha.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Renova Enterprise Management System

# E-mail via Resend — convites de usuário (/usuarios/convidar) e redefinição enviada pelo admin
RESEND_API_KEY=re_xxxxxxxx
# Sem domínio: onboarding@resend.dev (só envia para o e-mail da conta Resend ou testes @resend.dev)
# Com domínio verificado: Renova <noreply@seudominio.com>
RESEND_FROM_EMAIL=onboarding@resend.dev
