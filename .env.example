# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# App — use a URL pública (produção ou preview). Obrigatório no Vercel para links de convite e redefinição de senha.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Renova Enterprise Management System

# E-mail (recomendado: redefinição enviada por admin em /usuarios)
RESEND_API_KEY=sua_resend_key
# Remetente verificado no Resend, ex: Renova <noreply@seudominio.com>
RESEND_FROM_EMAIL=
